# ─────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in your values.
# ─────────────────────────────────────────────────────────────

# Groq API key — get one for free at https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# Optional overrides (defaults shown)
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_TEMPERATURE=0.1
# LLM_MAX_TOKENS=2048

# Turn LLM-based table enhancement off to skip all LLM calls during
# parsing (pages will just use PyMuPDF's layout-preserving text).
# Useful for fast debug runs.
# LLM_TABLE_ENHANCE=true

# Embedding device — set to "cuda" if you have a GPU.
# EMBEDDING_DEVICE=cpu

# Chunking
# CHUNK_SIZE=800
# CHUNK_OVERLAP=150

# Logging
# LOG_LEVEL=INFO
